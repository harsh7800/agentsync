{
  "name": "@agent-sync/cli",
  "version": "1.0.1",
  "description": "AI-assisted CLI for migrating AI agent configurations between Claude Code, Gemini CLI, OpenCode, Cursor, and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentsync": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "opencode",
    "cursor",
    "gemini",
    "copilot",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "migration",
    "configuration"
  ],
  "author": "AgentSync",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-sync/agentsync"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest --testPathPattern=cli",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-sync/core": "1.0.0",
    "@agent-sync/schemas": "1.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "inquirer": "^9.2.12",
    "log-symbols": "^7.0.1",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}