{
  "name": "@agent-sync/core",
  "version": "1.2.4",
  "description": "Core transformation logic for AgentSync CLI - parsers, translators, and migration utilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "claude",
    "opencode",
    "cursor",
    "gemini",
    "mcp",
    "ai-agent"
  ],
  "author": "AgentSync",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-sync/agentsync"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --testPathPattern=core",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "glob": "^13.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
