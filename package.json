{
  "name": "agentsync",
  "version": "1.1.0",
  "description": "AI-assisted CLI for migrating AI agent configurations between development tools",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-sync/agentsync"
  },
  "pnpm": {
    "overrides": {
      "string-width": "^4.2.3"
    }
  },
  "scripts": {
    "build": "pnpm -r exec rimraf dist tsconfig.tsbuildinfo && pnpm -r build",
    "dev": "pnpm --filter @agent-sync/cli dev",
    "start": "pnpm --filter @agent-sync/cli start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .ts",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.55.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.12.0"
}
